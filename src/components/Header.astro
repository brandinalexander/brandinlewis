---
const navLinks = [
  { href: "/#home", label: "Home" },
  { href: "/#services", label: "Services" },
  { href: "/#about", label: "About" },
  { href: "/#portfolio", label: "Portfolio" },
  { href: "/#contact", label: "Contact" },
];
---

<header
  class="border-b border-neutral-200"
  x-data="{ open: false }"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="font-display text-xl font-bold tracking-tight">Brandin Lewis</a>

    <nav class="hidden gap-8 md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium hover:underline">
          {link.label}
        </a>
      ))}
    </nav>

    <button
      type="button"
      class="md:hidden"
      @click="open = !open"
      aria-label="Toggle menu"
    >
      <span x-show="!open">Menu</span>
      <span x-show="open" x-cloak>Close</span>
    </button>
  </div>

  <nav
    x-show="open"
    x-cloak
    x-transition
    class="border-t border-neutral-200 px-6 py-4 md:hidden"
  >
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block text-sm font-medium" @click="open = false">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
