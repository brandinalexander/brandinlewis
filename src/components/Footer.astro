---
import ContactForm from "./ContactForm.astro";
---

<footer id="contact" class="border-t-2 border-ink bg-paper px-6 py-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12">
      <p class="text-sm uppercase tracking-widest text-muted">Contact</p>
      <h2 class="mt-2 font-display text-3xl font-bold">Got a project in mind?</h2>
    </div>
    <ContactForm />
    <p class="mt-12 text-sm text-muted">&copy; {new Date().getFullYear()} Brandin Lewis</p>
  </div>
</footer>
