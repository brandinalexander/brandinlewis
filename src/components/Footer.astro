---
import ContactForm from "./ContactForm.astro";
---

<footer id="contact" class="border-t border-neutral-200 bg-purple px-6 py-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12">
      <p class="text-sm uppercase tracking-widest text-neutral-600">Contact</p>
      <h2 class="mt-2 font-display text-3xl font-bold">Got a project in mind?</h2>
    </div>
    <ContactForm />
    <p class="mt-12 text-sm text-neutral-600">&copy; {new Date().getFullYear()} Brandin Lewis</p>
  </div>
</footer>
