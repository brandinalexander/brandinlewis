---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<form class="contact-form-block" action="#" method="post" id="contact-form">
  <div class="form-fields-grid">
    <div>
      <input
        class="text-field w-input"
        maxlength="256"
        name="Name"
        placeholder="What is your name *"
        type="text"
        id="Name"
        required
      />
    </div>
    <div>
      <input
        class="text-field w-input"
        maxlength="256"
        name="Email"
        placeholder="Your email address *"
        type="email"
        id="Email"
        required
      />
    </div>
    <div>
      <input
        class="text-field w-input"
        maxlength="256"
        name="Company-Name"
        placeholder="Your Company Name *"
        type="text"
        id="Company-Name"
        required
      />
    </div>
    <div>
      <input
        class="text-field w-input"
        maxlength="256"
        name="Phone-Number"
        placeholder="Your Phone Number *"
        type="tel"
        id="Phone-Number"
        required
      />
    </div>
    <div class="field-full">
      <textarea
        id="field-2"
        name="field-2"
        maxlength="5000"
        placeholder="Tell me about your project *"
        required
        class="textarea w-input"
      />
    </div>
  </div>
  {
    turnstileSiteKey ? (
      <div class="turnstile-placeholder">
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} />
      </div>
    ) : null
  }
  <div class="button cc-center">
    <div class="button-front">
      <input type="submit" class="button-text w-button" value="Submit" />
    </div>
    <div class="button-edge"></div>
  </div>
</form>

{
  turnstileSiteKey ? (
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    />
  ) : null
}

<script is:inline>
  document.getElementById('contact-form')?.addEventListener('submit', function () {
    var companyName = document.getElementById('Company-Name')?.value || '';
    window.posthog?.capture('contact_form_submitted', {
      has_company: companyName.length > 0,
    });
  });
</script>
