<!-- Stub: wire to Cloudflare Pages Function + Turnstile when ready -->
<form class="mx-auto max-w-xl space-y-4" action="#" method="post">
  <div>
    <label for="name" class="mb-1 block text-sm font-medium text-ink">Name</label>
    <input
      id="name"
      name="name"
      type="text"
      required
      class="w-full rounded-lg border-2 border-ink px-4 py-2 text-ink"
      placeholder="What is your name?"
    />
  </div>
  <div>
    <label for="email" class="mb-1 block text-sm font-medium text-ink">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      required
      class="w-full rounded-lg border-2 border-ink px-4 py-2 text-ink"
      placeholder="Your email address"
    />
  </div>
  <div>
    <label for="message" class="mb-1 block text-sm font-medium text-ink">Message</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      required
      class="w-full rounded-lg border-2 border-ink px-4 py-2 text-ink"
      placeholder="Tell me about your project"
    ></textarea>
  </div>
  <p class="text-xs text-muted">
    Turnstile verification and form handler coming soon.
  </p>
  <button
    type="submit"
    class="rounded-full border-2 border-ink bg-paper px-8 py-3 font-medium text-ink transition hover:bg-ink hover:text-paper"
  >
    Submit
  </button>
</form>
