---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Brandin Lewis">
  <Header />
  <main class="flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center">
    <p class="mb-4 text-sm uppercase tracking-widest text-neutral-500">Portfolio rebuild in progress</p>
    <h1 class="font-display text-5xl font-bold tracking-tight md:text-7xl">
      Brandin Lewis
    </h1>
    <p class="mt-6 max-w-xl text-lg text-neutral-600">
      Product optimalist. This site is being migrated from Webflow to Astro on Cloudflare Pages.
    </p>
    <a
      href="/project/united-nations-partner-portal"
      class="mt-10 inline-block rounded-full border-2 border-black px-8 py-3 font-medium transition hover:bg-black hover:text-white"
    >
      Preview a case study
    </a>
  </main>
  <Footer />
</Base>
