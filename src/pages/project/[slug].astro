---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProjectHeader from "../../components/ProjectHeader.astro";
import ProjectRelated from "../../components/ProjectRelated.astro";
import ProjectRichText from "../../components/ProjectRichText.astro";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  return projects.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry, projects },
  }));
}

const { entry, projects } = Astro.props;
---

<Base
  title={`${entry.data.title} — Brandin Lewis`}
  description={entry.data.description}
  ogImage={entry.data.heroImage}
  ogType="article"
>
  <Header />
  <ProjectHeader
    title={entry.data.title}
    description={entry.data.description}
    aboutIntro={entry.data.aboutIntro}
    client={entry.data.client}
    date={entry.data.date}
    services={entry.data.services}
    theme={entry.data.theme}
  />
  <section class="section">
    <div class="container">
      <div class="post-inner">
        <div class="project-details">
          <div class="main-image margin-bottom-70">
            <img
              src={entry.data.heroImage}
              loading="lazy"
              alt={`${entry.data.title} project screenshot`}
              class="image-frame"
            />
          </div>
          <div class="details">
            <ProjectRichText entry={entry} />
          </div>
          {
            entry.data.galleryImages.length > 0 && (
              <div class="gallery-collection-list">
                {entry.data.galleryImages.map((image, index) => (
                  <div class="collection-item">
                    <img
                      src={image}
                      loading="lazy"
                      alt={`${entry.data.title} gallery image ${index + 1}`}
                      class="image-frame"
                    />
                  </div>
                ))}
              </div>
            )
          }
        </div>
        <ProjectRelated relatedSlugs={entry.data.related} projects={projects} />
      </div>
    </div>
  </section>
  <Footer />
</Base>
