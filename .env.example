# Client-side PostHog (PUBLIC_ prefix ships in browser JS — use project token only, never personal API keys)
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token_here
# Same-origin reverse proxy path in production (see src/worker.ts). Dev server proxies /ingest via vite.
PUBLIC_POSTHOG_HOST=/ingest

# Cloudflare Turnstile site key (public — baked into HTML at build time)
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAyour_site_key_here
