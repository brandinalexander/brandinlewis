{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brandinlewis",
  "compatibility_date": "2026-07-05",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
